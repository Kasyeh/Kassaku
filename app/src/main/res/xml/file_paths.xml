<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- External files directory for downloads -->
    <external-files-path
        name="downloads"
        path="Download/" />
    
    <!-- Internal files directory as fallback -->
    <files-path
        name="internal_files"
        path="." />
    
    <!-- Cache directory -->
    <cache-path
        name="cache"
        path="." />
    
    <!-- External cache directory -->
    <external-cache-path
        name="external_cache"
        path="." />

    <!-- External storage directory (for Environment.getExternalStoragePublicDirectory) -->
    <external-path
        name="external_files"
        path="." />
</paths>
